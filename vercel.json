{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "MyIcon.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/main.py"
    },
    {
      "src": "/api/analyze",
      "dest": "/api/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/MyIcon.png",
      "dest": "/MyIcon.png"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}