{
  "version": 2,
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/main.py"
    },
    {
      "src": "/api/analyze",
      "dest": "/api/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/MyIcon.png",
      "dest": "/MyIcon.png"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}