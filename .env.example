# ── Vercel Environment Variables ──────────────────────────────────────────
# Copy these into your Vercel project dashboard:
#   Project → Settings → Environment Variables
#
# DO NOT commit real values to git. This file is for reference only.

# Your Groq API key (get it at https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The password clients must send in the x-api-key header
# Use any strong random string, e.g.: openssl rand -base64 32
A11Y_API_PASSWORD=change-me-to-something-strong
